{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wilkes",
  "version": "0.1.0",
  "identifier": "com.wilkes.app",
  "build": {
    "frontendDist": "../../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../ui run dev",
    "beforeBuildCommand": "npm --prefix ../ui run build"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/*", "../worker/wilkes_worker", "../worker/wilkes_worker.py"]
  },
  "app": {
    "windows": [
      {
        "title": "Wilkes",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 200,
        "titleBarStyle": "Transparent"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  }
}
