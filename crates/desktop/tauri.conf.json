{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wilkes",
  "version": "0.1.0",
  "identifier": "app.wilkes",
  "build": {
    "frontendDist": "../../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "node ../scripts/prepare-sidecar.mjs && npm --prefix ../ui run dev",
    "beforeBuildCommand": "node ../scripts/prepare-sidecar.mjs --release && npm --prefix ../ui run build"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/wilkes-rust-worker"],
    "resources": {
      "../worker/wilkes_python_worker": "wilkes_python_worker",
      "../worker/requirements.txt": "requirements.txt"
    }
  },
  "app": {
    "windows": [
      {
        "title": "Wilkes",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 200,
        "titleBarStyle": "Transparent"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  }
}
